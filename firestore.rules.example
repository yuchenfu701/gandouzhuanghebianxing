rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * 将 YOUR_SYNC_TOKEN 替换为后台「云同步」里保存的「同步文档 ID」（与 localStorage 中 cloudSyncToken 一致）。
     * 若使用 sync-public-config.js 让访客自动拉取，其中的 syncDocId 须与本处一致；知悉该 ID 的客户端可按规则读写该文档，请使用足够长的随机 ID。
     */
    match /wilsonSiteSync/{docId} {
      allow read, write: if docId == "YOUR_SYNC_TOKEN";
    }
  }
}
